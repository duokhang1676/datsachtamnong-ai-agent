# Root level gitignore

# Environment files
.env
.env.local
.env.production
.env.*.local

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
.cache/

# Build artifacts and dependencies
node_modules/
dist/
coverage/

# TypeScript build info
*.tsbuildinfo

# test file
*test*
