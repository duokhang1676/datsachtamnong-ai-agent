# Core App
NODE_ENV=development
PORT=4000
APP_BASE_URL= http://localhost:4000

# AI / Model Providers
OPENAI_API_KEY=
PEXELS_API_KEY=

# Backend API Integration
API_BASE_URL= http://localhost:5000/api
AGENT_EMAIL=
AGENT_PASSWORD=

# Content Workflow
DEFAULT_NEWS_CATEGORY_ID=
NEWS_PUBLISH_CRON_ENABLED=true
NEWS_PUBLISH_CRON=0 10 * * *
NEWS_PUBLISH_CRON_TIMEZONE=Asia/Ho_Chi_Minh
NEWS_PUBLISH_ON_STARTUP=false

# Notification Email
DISABLE_NOTIFICATION_EMAIL=false
#1st priority: reviewer email
REVIEWER_EMAIL=
#2nd priority: notification email
NOTIFICATION_EMAIL=

RESEND_API_KEY=

RESEND_FROM_EMAIL=
#sender fallback
EMAIL_FROM=
EMAIL_USER=

# Google Cloud TTS
GCP_PROJECT_ID=
GCP_TTS_VOICE_NAME=vi-VN-Neural2-A
# Option A: pass raw JSON string from service account key (recommended on Render)
GCP_TTS_CREDENTIALS_JSON=
# Option B: use file path with Google ADC (local/dev)
GOOGLE_APPLICATION_CREDENTIALS=